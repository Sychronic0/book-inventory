# Python bytecode
__pycache__/
*.pyc
*.pyo

# Local SQLite database (each user keeps their own library)
library.db
library.db.bak
*.bak

# Migration backup created by database.init_db() before destructive work.
# Always an automatic artifact; never commit it.
library.db.migrating

# Editor / IDE
.idea/

# Local secrets — never commit
.discord_webhook
*.env
.env
